// ============================================================
// Prisma Schema — DailySpend Expense Tracker
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Expense {
  id            String   @id @db.VarChar(255)
  amount        Float
  date          DateTime
  categoryIndex Int      @map("category_index")
  note          String?  @db.Text
  isIncome      Boolean  @default(false) @map("is_income")
  currencyCode  String   @default("USD") @map("currency_code") @db.VarChar(10)

  @@index([date(sort: Desc)])
  @@map("expenses")
}
