// ============================================================
// Prisma Schema — Project PET (Personal Expense Tracker)
// PRD v3.1 §20 Data Models
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// Users (backend only — mobile uses implicit single-user)
// ──────────────────────────────────────────────────────────────
model User {
  id                  String   @id @default(uuid()) @db.Uuid
  email               String   @unique @db.VarChar(255)
  displayName         String   @map("display_name") @db.VarChar(100)
  avatarUrl           String?  @map("avatar_url") @db.Text
  baseCurrency        String   @default("AUD") @map("base_currency") @db.VarChar(3)
  authProvider        String   @map("auth_provider") @db.VarChar(10) // google | apple
  providerId          String   @map("provider_id") @db.VarChar(255)
  googleRefreshToken  String?  @map("google_refresh_token") @db.Text
  sheetsSpreadsheetId String?  @map("sheets_spreadsheet_id") @db.Text
  sheetsEnabled       Boolean  @default(false) @map("sheets_enabled")
  fcmToken            String?  @map("fcm_token") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  transactions     Transaction[]
  categories       Category[]
  budgets          Budget[]
  currencyBalances CurrencyBalance[]
  conflictLogs     ConflictLog[]

  @@map("users")
}

// ──────────────────────────────────────────────────────────────
// Transactions (unified: expense, currency_income, exchange)
// ──────────────────────────────────────────────────────────────
model Transaction {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  transactionType  String    @map("transaction_type") @db.VarChar(25)
  // expense | currency_income | currency_exchange_out | currency_exchange_in
  amountBase       Decimal   @map("amount_base") @db.Decimal(12, 4)
  originalAmount   Decimal   @map("original_amount") @db.Decimal(12, 4)
  originalCurrency String    @map("original_currency") @db.VarChar(3)
  exchangeRate     Decimal   @map("exchange_rate") @db.Decimal(10, 6)
  rateDate         DateTime  @map("rate_date") @db.Date
  rateEstimated    Boolean   @default(false) @map("rate_estimated")
  rateSource       String    @default("frankfurter") @map("rate_source") @db.VarChar(15)
  // frankfurter | custom | estimated
  exchangeEventId  String?   @map("exchange_event_id") @db.Uuid
  categoryId       String?   @map("category_id") @db.Uuid
  note             String?   @db.Text
  sourceLabel      String?   @map("source_label") @db.Text
  transactionDate  DateTime  @map("transaction_date") @db.Date
  isRecurring      Boolean   @default(false) @map("is_recurring")
  recurrenceType   String?   @map("recurrence_type") @db.VarChar(12)
  // weekly | fortnightly | monthly | null
  deletedAt        DateTime? @map("deleted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, transactionDate(sort: Desc)])
  @@index([userId, transactionType])
  @@index([exchangeEventId])
  @@map("transactions")
}

// ──────────────────────────────────────────────────────────────
// Categories
// ──────────────────────────────────────────────────────────────
model Category {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(50)
  colourHex String   @map("colour_hex") @db.VarChar(7)
  isDefault Boolean  @default(false) @map("is_default")
  isHidden  Boolean  @default(false) @map("is_hidden")
  sortOrder Int      @map("sort_order")
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  subCategories Category[]   @relation("SubCategories")
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
  @@index([parentId])
  @@map("categories")
}

// ──────────────────────────────────────────────────────────────
// Budgets
// ──────────────────────────────────────────────────────────────
model Budget {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  scope        String    @db.VarChar(10) // global | category
  categoryId   String?   @map("category_id") @db.Uuid
  amountBase   Decimal   @map("amount_base") @db.Decimal(12, 2)
  periodType   String    @map("period_type") @db.VarChar(12)
  // weekly | fortnightly | monthly | custom
  startDate    DateTime  @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  isActive     Boolean   @default(true) @map("is_active")
  notified80   Boolean   @default(false) @map("notified_80")
  notified100  Boolean   @default(false) @map("notified_100")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("budgets")
}

// ──────────────────────────────────────────────────────────────
// Exchange Rates (cache)
// ──────────────────────────────────────────────────────────────
model ExchangeRate {
  id            String   @id @default(uuid()) @db.Uuid
  baseCurrency  String   @map("base_currency") @db.VarChar(3)
  quoteCurrency String   @map("quote_currency") @db.VarChar(3)
  rate          Decimal  @db.Decimal(10, 6)
  rateDate      DateTime @map("rate_date") @db.Date
  fetchedAt     DateTime @default(now()) @map("fetched_at")
  source        String   @default("frankfurter") @db.VarChar(20)

  @@unique([baseCurrency, quoteCurrency, rateDate])
  @@map("exchange_rates")
}

// ──────────────────────────────────────────────────────────────
// Currency Balances (derived, kept in sync)
// ──────────────────────────────────────────────────────────────
model CurrencyBalance {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  currency  String   @db.VarChar(3)
  balance   Decimal  @db.Decimal(12, 4)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@map("currency_balances")
}

// ──────────────────────────────────────────────────────────────
// Conflict Log (backend only)
// ──────────────────────────────────────────────────────────────
model ConflictLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  recordType     String   @map("record_type") @db.VarChar(20)
  recordId       String   @map("record_id") @db.Uuid
  winningVersion Json     @map("winning_version")
  losingVersion  Json     @map("losing_version")
  resolvedAt     DateTime @default(now()) @map("resolved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("conflict_log")
}
