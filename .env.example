# ============================================================
# Environment Variables — copy to .env and fill in values
# ============================================================

# PostgreSQL (used by Docker Compose)
POSTGRES_USER=expense_user
POSTGRES_PASSWORD=expense_password
POSTGRES_DB=expense_db

# Prisma (used by NestJS API — set in apps/api/.env)
# DATABASE_URL="postgresql://expense_user:expense_password@localhost:5432/expense_db"

# Google Sheets API (OAuth Client config for generating spreadsheet on behalf of user)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Firebase Cloud Messaging (Service Account JSON fields)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
